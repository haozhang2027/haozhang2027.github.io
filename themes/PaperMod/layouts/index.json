{{- $pages := where (where .Site.RegularPages "Draft" false) "Section" "posts" -}}
[
{{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "permalink": {{ $p.Permalink | jsonify }},
    "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
    "summary": {{ $p.Summary | plainify | jsonify }},
    "content": {{ $p.Plain | jsonify }},
    "tags": {{ $p.Params.tags | jsonify }}
  }
{{- end -}}
]
